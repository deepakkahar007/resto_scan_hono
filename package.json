{
  "name": "server",
  "module": "src/server.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --minify",
    "zip": "zip -j lambda.zip dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^1.0.0-beta.19",
    "esbuild": "^0.27.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.3",
    "@neondatabase/serverless": "^1.0.2",
    "@scalar/hono-api-reference": "^0.10.5",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^1.0.0-beta.19",
    "hono": "^4.12.9",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  }
}
